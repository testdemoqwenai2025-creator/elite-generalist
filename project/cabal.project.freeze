-- =============================================================================
--  cabal.project.freeze
--  ---------------------------------------------------------------------------
--  Pinned dependency versions for byte-identical reproducible builds.
--
--  Regenerate locally with:
--      cabal v2-freeze
--  Commit the result.  Phase 4 of the pipeline ("Package") depends on this
--  being in source control.
--
--  Versions are the latest stable as of the last `cabal v2-update`; rotate
--  via PR, never silently.
-- =============================================================================
active-repositories: hackage.haskell.org
constraints: any.Cabal ==3.10.1.0
             any.HUnit ==1.6.2.0
